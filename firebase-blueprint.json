{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and access control",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isUltimateAdmin": { "type": "boolean" },
        "isOriginalAdmin": { "type": "boolean" },
        "notifiedApproved": { "type": "boolean" }
      },
      "required": ["uid", "username", "email", "status", "role", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Laptop inventory transaction record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["INCOMING", "REPAIR", "SALE", "ADJUSTMENT", "BREAKDOWN", "PURCHASE", "INSTALL"] },
        "batchId": { "type": "string" },
        "batchActive": { "type": "boolean" },
        "brand": { "type": "string" },
        "series": { "type": "string" },
        "model": { "type": "string" },
        "fromClass": { "type": "string" },
        "toClass": { "type": "string" },
        "quantity": { "type": "integer" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "notes": { "type": "string" },
        "componentChanges": { "type": "object" }
      },
      "required": ["type", "batchId", "brand", "series", "model", "quantity", "timestamp", "userId"]
    },
    "ComponentTransaction": {
      "title": "ComponentTransaction",
      "description": "Component inventory transaction record",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["BREAKDOWN", "INCOMING", "SALE", "ADJUSTMENT", "PURCHASE", "INSTALL"] },
        "brand": { "type": "string" },
        "series": { "type": "string" },
        "model": { "type": "string" },
        "fromClass": { "type": "string" },
        "laptopQuantity": { "type": "integer" },
        "componentChanges": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["type", "brand", "series", "model", "componentChanges", "timestamp", "userId"]
    },
    "Batch": {
      "title": "Batch",
      "description": "Inventory batch record",
      "type": "object",
      "properties": {
        "batchId": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["batchId", "items", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProfile",
      "description": "Collection of user profiles"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Collection of laptop transactions"
    },
    "component_transactions": {
      "schema": "ComponentTransaction",
      "description": "Collection of component transactions"
    },
    "batches": {
      "schema": "Batch",
      "description": "Collection of inventory batches"
    }
  }
}
